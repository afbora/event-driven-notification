# Dockerfile.dev — development image used by docker-compose for api / worker / reconciler.
#
# Source is bind-mounted into /src at runtime; `air` rebuilds on file changes.
# The production image (single-binary, distroless) lives in `Dockerfile`.
#
# This image and the production image share the same Go line (1.26), aligned
# with go.mod and CLAUDE.md §6.

ARG GO_VERSION=1.26

FROM golang:${GO_VERSION}-alpine

RUN apk add --no-cache git curl tzdata ca-certificates make

# Install air for hot reload. Pinned to a major version line; bump explicitly
# when tooling upgrades are intentional.
RUN go install github.com/air-verse/air@latest

WORKDIR /src

# The actual command (`air -c .air.<binary>.toml`) is provided by compose.
